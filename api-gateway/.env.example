# ─── Ambiente ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── URLs dos microserviços ─────────────────────────────────────────────────────
EMPRESAS_SERVICE_URL=http://localhost:3002
PRODUCAO_SERVICE_URL=http://localhost:3001

# ─── Autenticação (Authentik OIDC) ─────────────────────────────────────────────
# URL interna do Authentik para buscar chaves públicas (JWKS)
AUTHENTIK_JWKS_URL=http://localhost:9000/application/o/calcados-padilha/jwks/

# Issuer declarado no JWT emitido pelo Authentik
AUTHENTIK_ISSUER=http://localhost:9000/application/o/calcados-padilha/

# URL base do Authentik usada no fluxo de login
AUTHENTIK_URL=http://localhost:9000

# Client ID da aplicação configurada no Authentik
AUTHENTIK_CLIENT_ID=calcados-padilha

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Origin do frontend (usado no enableCors)
CORS_ORIGIN=http://localhost:5173

# Redirect URI após login OAuth2
FRONTEND_URL=http://localhost:5173/
