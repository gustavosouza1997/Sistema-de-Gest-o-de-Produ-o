# ─── Ambiente ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ─── Banco de dados (PostgreSQL) ───────────────────────────────────────────────
DATABASE_HOST=localhost
DATABASE_PORT=5433
DATABASE_NAME=producao_db
DATABASE_USER=admin
DATABASE_PASSWORD=admin

# Sincroniza o schema automaticamente (só usar em development)
TYPEORM_SYNC=true

# ─── RabbitMQ (ainda não consumido, mas necessário para quando os consumers forem implementados) ─
RABBITMQ_URL=amqp://admin:admin@localhost:5672
