# ─── PostgreSQL ────────────────────────────────────────────────────────────────
# Usado por: postgres-empresas, postgres-producao (via docker-compose)
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin

# ─── RabbitMQ ──────────────────────────────────────────────────────────────────
# Usado por: rabbitmq (via docker-compose)
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin

# ─── Authentik (Identity Provider) ────────────────────────────────────────────
# Banco de dados interno do Authentik
AUTHENTIK_DB_PASSWORD=authentik

# Chave secreta de criptografia — NÃO alterar em produção sem migrar os dados
AUTHENTIK_SECRET_KEY=sua-chave-secreta-aqui

# Credenciais do admin criadas no primeiro boot (bootstrap)
AUTHENTIK_BOOTSTRAP_PASSWORD=Admin1234!
AUTHENTIK_BOOTSTRAP_TOKEN=bootstrap-token-dev

# OAuth2 Application configurado no Authentik
AUTHENTIK_CLIENT_ID=calcados-padilha

# ─── Frontend (Grafana) ────────────────────────────────────────────────────────
# Usado por: grafana (via docker-compose)
GF_AUTH_ANONYMOUS_ENABLED=true
GF_AUTH_ANONYMOUS_ORG_ROLE=Admin
GF_AUTH_DISABLE_LOGIN_FORM=false
